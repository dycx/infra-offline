{
  "name": "myapp",
  "version": "1.0.0",
  "description": "Electron + C++ backend (MinGW)",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win portable",
    "backend:build": "cd backend && mkdir -p build && cd build && cmake .. -G \"MinGW Makefiles\" && mingw32-make"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.company.myapp",
    "productName": "MyApp",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "backend/build/backend.exe",
        "to": "backend.exe"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    }
  }
}
